# SMTP — varianta A: bilo koji server (host + port)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Varianta B: Gmail bez hosta — stavi SMTP_SERVICE=gmail i iskommentariši SMTP_HOST ako želiš
# SMTP_SERVICE=gmail

SMTP_USER=
SMTP_PASS=

# Primaoci (jedan ili više, odvojeni zarezom)
MAIL_TO=

# Pošiljalac u inboxu (opciono; podrazumevano SMTP_USER)
# MAIL_FROM="Cyber Tracking <podrska@gpspracenje.rs>"

# Reply-To zaglavlje (opciono)
# MAIL_REPLY_TO=
